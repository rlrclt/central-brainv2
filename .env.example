# API Keys for Central Brain Integration
# Copy this to .env and fill in your actual keys

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# OpenAI GPT
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# Google Gemini
GOOGLE_API_KEY=xxxxxxxxxxxxx

# Central Brain Server (default: localhost:7799)
CENTRAL_BRAIN_URL=http://localhost:7799

# Copilot Settings (if using Copilot as an agent)
COPILOT_ENABLED=true
COPILOT_NAME=copilot-cli
